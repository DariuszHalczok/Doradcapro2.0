<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nowa Struktura Dokumentacji - OVB</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        ovb: {
                            /* Primary Colors */
                            blue: '#003366',
                            white: '#FFFFFF',
                            /* Additional gradations */
                            'blue-medium': '#336699',
                            'blue-light': '#6699CC',
                            'light-grey': '#E5E5E5',
                            'lettering-white': '#F2F2F2',
                            /* Secondary Colors (Main & Light/Dark tones) */
                            teal: '#009999',
                            ocean: '#006666',
                            sapphire: '#66CCCC',
                            'hot-pink': '#FF3399',
                            orchid: '#9966CC'
                        }
                    },
                    fontFamily: {
                        /* Zgodnie z wytycznymi OVB */
                        sans: ['"Stag Sans"', '"Segoe UI"', 'system-ui', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        /* Ustawienia specyficzne dla generowania PDF i druku */
        @page {
            size: A4;
            margin: 0;
        }
        @media print {
            body { 
                background-color: white !important; 
                margin: 0;
                padding: 0;
                -webkit-print-color-adjust: exact;
                print-color-adjust: exact;
            }
            .a4-page {
                box-shadow: none !important;
                border: none !important;
                width: 100% !important;
                height: 100% !important;
                margin: 0 !important;
            }
        }
    </style>
</head>
<body class="bg-gray-200 font-sans text-gray-800 antialiased flex justify-center py-8 print:py-0 print:bg-white">

    <!-- Kontener o sztywnych wymiarach A4 -->
    <div class="a4-page w-[210mm] h-[297mm] bg-white shadow-2xl overflow-hidden relative box-border flex flex-col">
        
        <!-- STRONA TYTUŁOWA (Nagłówek) -->
        <div class="bg-ovb-blue text-white p-8 text-center relative border-b-[6px] border-ovb-teal flex-shrink-0">
            <h1 class="text-3xl font-bold mb-2 mt-4">Komplet Dokumentacji Ubezpieczeniowej</h1>
            <h2 class="text-xl text-ovb-blue-light font-light mb-6">Umowa Grupowego Ubezpieczenia na Życie CERTUM</h2>
            
            <div class="bg-ovb-blue-medium bg-opacity-80 inline-block p-4 rounded-lg text-left w-full max-w-sm mx-auto border border-ovb-blue-light">
                <p class="text-xs text-ovb-light-grey uppercase tracking-wider mb-1">Dla Klienta</p>
                <p class="text-lg font-bold text-white mb-3">Maksymilian Sikorski</p>
                <p class="text-xs text-ovb-light-grey uppercase tracking-wider mb-1">Numer Polisy / Certyfikatu</p>
                <p class="text-base font-bold text-white">90000785745_3</p>
            </div>
        </div>

        <!-- SPIS TREŚCI (Zawartość) -->
        <div class="px-10 py-8 bg-white flex-1">
            <h3 class="text-2xl font-bold text-ovb-blue mb-5 border-b-2 border-ovb-light-grey pb-2">Spis treści</h3>
            
            <div class="space-y-5">
                <!-- Krok 1 -->
                <div class="flex items-start">
                    <div class="flex-shrink-0 w-10 h-10 bg-ovb-lettering-white rounded-full flex items-center justify-center text-ovb-blue font-bold text-lg mr-4 border-2 border-ovb-blue-light">1</div>
                    <div class="flex-1 border-b border-dashed border-ovb-light-grey pb-3">
                        <h4 class="text-lg font-bold text-ovb-blue flex justify-between items-center">
                            <span>Karta Dystrybutora i Obowiązek Informacyjny</span>
                            <span class="text-gray-400 text-xs font-normal">Strona 3</span>
                        </h4>
                        <p class="text-gray-600 text-sm mt-0.5">Dane Agenta, wpis do rejestru KNF, informacje o wynagrodzeniu, zasady składania reklamacji.</p>
                        <span class="inline-block mt-1.5 px-2 py-0.5 bg-ovb-teal bg-opacity-10 text-ovb-ocean text-[10px] uppercase font-bold rounded">Wymóg KNF - IDD</span>
                    </div>
                </div>

                <!-- Krok 2 -->
                <div class="flex items-start">
                    <div class="flex-shrink-0 w-10 h-10 bg-ovb-lettering-white rounded-full flex items-center justify-center text-ovb-blue font-bold text-lg mr-4 border-2 border-ovb-blue-light">2</div>
                    <div class="flex-1 border-b border-dashed border-ovb-light-grey pb-3">
                        <h4 class="text-lg font-bold text-ovb-blue flex justify-between items-center">
                            <span>Analiza Potrzeb Klienta (APK)</span>
                            <span class="text-gray-400 text-xs font-normal">Strona 6</span>
                        </h4>
                        <p class="text-gray-600 text-sm mt-0.5">Ankieta określająca Twoje potrzeby oraz dopasowująca odpowiedni zakres ubezpieczenia.</p>
                        <span class="inline-block mt-1.5 px-2 py-0.5 bg-ovb-teal bg-opacity-10 text-ovb-ocean text-[10px] uppercase font-bold rounded">Wymóg KNF - IDD</span>
                    </div>
                </div>

                <!-- Krok 3 -->
                <div class="flex items-start">
                    <div class="flex-shrink-0 w-10 h-10 bg-ovb-lettering-white rounded-full flex items-center justify-center text-ovb-blue font-bold text-lg mr-4 border-2 border-ovb-blue-light">3</div>
                    <div class="flex-1 border-b border-dashed border-ovb-light-grey pb-3">
                        <h4 class="text-lg font-bold text-ovb-blue flex justify-between items-center">
                            <span>Deklaracja Przystąpienia do Ubezpieczenia</span>
                            <span class="text-gray-400 text-xs font-normal">Strona 7</span>
                        </h4>
                        <p class="text-gray-600 text-sm mt-0.5">Twoje dane osobowe, wskazanie uposażonych, oświadczenie o stanie zdrowia, wybór pakietów.</p>
                        <span class="inline-block mt-1.5 px-2 py-0.5 bg-ovb-blue-light bg-opacity-20 text-ovb-blue text-[10px] uppercase font-bold rounded">Dokument Główny</span>
                    </div>
                </div>

                <!-- Krok 4 -->
                <div class="flex items-start">
                    <div class="flex-shrink-0 w-10 h-10 bg-ovb-lettering-white rounded-full flex items-center justify-center text-ovb-blue font-bold text-lg mr-4 border-2 border-ovb-blue-light">4</div>
                    <div class="flex-1 border-b border-dashed border-ovb-light-grey pb-3">
                        <h4 class="text-lg font-bold text-ovb-blue flex justify-between items-center">
                            <span>Oświadczenie o źródle pochodzenia majątku</span>
                            <span class="text-gray-400 text-xs font-normal">Strona 10</span>
                        </h4>
                        <p class="text-gray-600 text-sm mt-0.5">Wymagane prawem informacje dotyczące źródła finansowania składek.</p>
                        <span class="inline-block mt-1.5 px-2 py-0.5 bg-ovb-light-grey text-gray-700 text-[10px] uppercase font-bold rounded">Wymóg Prawny - AML</span>
                    </div>
                </div>

                <!-- Krok 5 -->
                <div class="flex items-start">
                    <div class="flex-shrink-0 w-10 h-10 bg-ovb-lettering-white rounded-full flex items-center justify-center text-ovb-blue font-bold text-lg mr-4 border-2 border-ovb-blue-light">5</div>
                    <div class="flex-1 pb-1">
                        <h4 class="text-lg font-bold text-ovb-blue flex justify-between items-center">
                            <span>Informacja o Przetwarzaniu Danych (RODO)</span>
                            <span class="text-gray-400 text-xs font-normal">Strona 11</span>
                        </h4>
                        <p class="text-gray-600 text-sm mt-0.5">Informacje o przetwarzaniu danych przez OVB, Stowarzyszenie oraz Generali Życie T.U. S.A.</p>
                        <span class="inline-block mt-1.5 px-2 py-0.5 bg-ovb-light-grey text-gray-700 text-[10px] uppercase font-bold rounded">Informacja RODO</span>
                    </div>
                </div>
            </div>

        </div>

    </div>

</body>
</html>
