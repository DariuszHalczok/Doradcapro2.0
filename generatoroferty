<script>
  // Mechanizm omijający blokady skryptów wewnątrz ClickFunnels
  // Skrypt czeka, aż zewnętrzne pliki CDN (Babel, React) się pobiorą, a następnie RĘCZNIE kompiluje kod JSX.
  (function() {
    var attempts = 0;
    
    function init() {
      // Sprawdzamy czy niezbędne biblioteki zostały załadowane
      if (typeof window.Babel !== 'undefined' && typeof window.React !== 'undefined' && typeof window.ReactDOM !== 'undefined') {
        try {
          // Pobieramy bezpieczny kod jako zwykły tekst
          var source = document.getElementById('ovb-react-source').textContent || document.getElementById('ovb-react-source').innerText;
          
          // Kompilujemy manualnie
          var compiled = window.Babel.transform(source, { presets: ['env', 'react'] }).code;
          
          // Wrzucamy do standardowego tagu SCRIPT na samym dole body (Bypass ClickFunnels dom parser)
          var script = document.createElement('script');
          script.type = 'text/javascript';
          script.innerHTML = compiled + "\n" +
          "var rootElement = document.getElementById('ovb-app-root');\n" +
          "if (rootElement) {\n" +
          "    rootElement.innerHTML = '';\n" +
          "    var root = ReactDOM.createRoot(rootElement);\n" +
          "    root.render(React.createElement(InsuranceDashboard));\n" +
          "}";
          document.body.appendChild(script);
          
        } catch (err) {
          console.error('Błąd kompilatora Babel: ', err);
          document.getElementById('ovb-app-root').innerHTML = '<div style="color:#CC0066; padding:20px; font-family: sans-serif; text-align: center;"><b>Błąd kompilacji.</b><br/>Sprawdź konsolę przeglądarki. Skontaktuj się ze wsparciem technicznym.</div>';
        }
      } else {
        // Ponawiaj próbę załadowania przez 10 sekund (100 prób co 100ms)
        attempts++;
        if(attempts < 100) {
           setTimeout(init, 100);
        } else {
           document.getElementById('ovb-app-root').innerHTML = '<div style="color:#CC0066; padding:20px; font-family: sans-serif; text-align: center;"><b>Nie można załadować wymaganych plików.</b><br/>Twoja przeglądarka lub ad-blocker blokuje zewnętrzne biblioteki (React/Babel).</div>';
        }
      }
    }
    
    // Uruchomienie bezpiecznej pętli sprawdzającej po załadowaniu drzewa strony
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init);
    } else {
      init();
    }
  })();
</script>
