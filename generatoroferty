    const basePrice = currentPackage ? currentPackage.price : 0;
    const totalMonthly = basePrice + selectedAddons.reduce((sum, id) => {
        const addon = (currentOfferData && currentOfferData.addons) ? currentOfferData.addons.find(a => a.id === id) : null;
        return sum + (addon ? addon.price : 0);
    }, 0);

    const offerRef = useRef(null);

    const handleDownload = async (onlySelected) => {
        if (!offerRef.current || typeof window.html2canvas === 'undefined') {
            alert("Trwa ładowanie biblioteki do generowania obrazu. Spróbuj za chwilę.");
            return;
        }
        
        const offerElement = offerRef.current;
        const originalTransform = offerElement.style.transform;
        const originalMarginBottom = offerElement.style.marginBottom;
        offerElement.style.transform = 'none';
        offerElement.style.marginBottom = '0';
        
        if (onlySelected === true) {
            offerElement.classList.add('card-mode');
            const allPkgCells = offerElement.querySelectorAll('[data-pkg]');
            for(let i=0; i<allPkgCells.length; i++) {
                if (allPkgCells[i].getAttribute('data-pkg') !== selectedPkgId) allPkgCells[i].style.display = 'none';
            }
            const allCegielki = offerElement.querySelectorAll('.cegielka');
            for(let i=0; i<allCegielki.length; i++) {
                 const id = allCegielki[i].id.replace('cegielka-', '');
                 if (!selectedAddons.includes(id) && id) allCegielki[i].style.display = 'none';
            }
        }

        try {
            const slides = [
                offerElement.querySelector('#page-1'),
                offerElement.querySelector('#page-2')
            ];
            
            const nameSuffix = (clientData && clientData.name) ? '_' + clientData.name.replace(/\s/g, '_') : '';
            const baseFname = (onlySelected === true) ? 'Wybrany_Pakiet_OVB' + nameSuffix : 'Propozycja_Ochrony_OVB' + nameSuffix;
            
            for (let i = 0; i < slides.length; i++) {
                const slide = slides[i];
                if (!slide) continue;

                const canvas = await window.html2canvas(slide, { 
                    scale: 2, 
                    useCORS: true, 
                    logging: false,
                    backgroundColor: '#ffffff'
                });
                
                const imgData = canvas.toDataURL('image/png');
                const link = document.createElement('a');
                link.download = baseFname + '_Strona_' + (i + 1) + '.png';
                link.href = imgData;
                link.click();
                
                await new Promise(resolve => setTimeout(resolve, 300));
            }
            
        } catch (err) {
            console.error(err);
            alert("Błąd generowania plików PNG.");
        } finally {
            offerElement.style.transform = originalTransform || '';
            offerElement.style.marginBottom = originalMarginBottom || '';
            
            if (onlySelected === true) {
                offerElement.classList.remove('card-mode');
                const allPkgCells = offerElement.querySelectorAll('[data-pkg]');
                for(let i=0; i<allPkgCells.length; i++) { allPkgCells[i].style.display = ''; }
                const allCegielki = offerElement.querySelectorAll('.cegielka');
                for(let i=0; i<allCegielki.length; i++) { allCegielki[i].style.display = ''; }
            }
        }
