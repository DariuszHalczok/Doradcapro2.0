        }

        .generali-block ol.main-list > li > span {
            font-weight: 400;
            color: var(--generali-dark);
            display: block;
            margin-top: 8px;
        }

        .generali-sublist {
            list-style-type: none;
            padding-left: 0;
            counter-reset: subitem;
            margin-top: 10px;
            font-weight: 400;
            color: var(--generali-dark);
        }

        .generali-sublist > li {
            position: relative;
            padding-left: 25px;
            margin-bottom: 8px;
            line-height: 1.5;
        }

        .generali-sublist > li::before {
            counter-increment: subitem;
            content: counter(subitem) ")";
            position: absolute;
            left: 0;
            font-weight: 600;
        }

        .generali-footer {
            font-size: 10px;
            color: #888;
            border-top: 1px solid #ddd;
            padding-top: 15px;
            margin-top: 40px;
            text-align: justify;
            line-height: 1.4;
        }

        .generali-footer-code {
            font-weight: bold;
            text-align: right;
            margin-top: 10px;
            font-size: 11px;
        }

        @media (max-width: 768px) {
            .info-grid { grid-template-columns: 1fr; }
            .document-container { padding: 30px 20px; }
