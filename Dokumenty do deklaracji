        .ovb-section li { margin-bottom: 8px; }
        .ovb-section strong { color: var(--text-dark); }

        .highlight-box {
            background: #E3F2FD;
            border-left: 4px solid #2196F3;
            padding: 15px 20px;
            border-radius: 0 8px 8px 0;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .alert-box {
            background: #FFF9C4;
            border-left: 4px solid #FBC02D;
            padding: 15px 20px;
            border-radius: 0 8px 8px 0;
            margin-bottom: 20px;
            font-size: 14px;
        }

        .knf-links {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 15px;
        }

        .knf-links a {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--ovb-teal);
            text-decoration: none;
            font-weight: 600;
            padding: 10px 15px;
            border: 1px solid var(--ovb-teal);
            border-radius: 6px;
            transition: 0.2s;
            width: fit-content;
            font-size: 14px;
        }

        .knf-links a:hover {
            background: var(--ovb-teal);
            color: white;
        }

        .admin-cards {
            display: grid;
            grid-template-columns: 1fr;
            gap: 15px;
            margin-bottom: 25px;
        }

        /* --- PAGE BREAK / SEPARATOR --- */
        .section-separator {
            margin: 60px 0;
            border: none;
            border-top: 2px dashed var(--border-color);
        }
        
        .page-break {
            page-break-before: always;
        }

        /* --- GENERALI STYLES (Part 3) --- */
        .generali-block {
            color: var(--generali-dark);
            font-size: 14px;
        }
        
        .generali-header-container {
            border-bottom: 3px solid var(--generali-red);
            padding-bottom: 15px;
            margin-bottom: 30px;
        }

        .generali-logo {
            font-size: 28px;
            font-weight: 800;
            color: var(--generali-red);
            letter-spacing: 1px;
            margin-bottom: 5px;
        }

        .generali-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--text-dark);
            text-transform: uppercase;
        }

        .generali-block ol.main-list {
            list-style-type: decimal;
            padding-left: 20px;
            font-weight: 700;
            color: var(--generali-red);
        }

        .generali-block ol.main-list > li {
