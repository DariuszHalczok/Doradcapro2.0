        <!-- STEP 9: PŁATNOŚĆ -->
        <div id="step-9" class="step-content">
            <h1 class="page-title" style="text-align:center">Dziękujemy!</h1>
            <div class="form-section" style="text-align:center">
                Wniosek przyjęty do realizacji.<br><br>
                <div style="background:#f9f9f9; padding:15px; border-radius:8px; display:inline-block; text-align:left;">
                    <strong>Dane do przelewu:</strong><br>
                    Rachunek: 97 1030 1944 4702 9940 2030 3546<br>
                    Kwota: <span id="finalAmount">--</span>
                </div>
