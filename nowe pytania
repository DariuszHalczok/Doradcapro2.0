    </div>

    <!-- Sticky & Modal -->
    <div class="sticky-summary" id="stickySummary"><div class="sticky-content"><div><span class="total-label" style="font-size:0.8em; color:#777;">Składka:</span><span class="total-price" id="stickyPrice" style="font-size:1.3em;">0,00 zł</span></div><button class="sticky-btn" onclick="App.nextStep()" style="padding:10px 20px;">Dalej</button></div></div>
    <div class="modal-overlay" id="validationModal"><div class="modal-box"><div class="modal-title">Uwaga</div><div class="modal-list" id="modalErrorList"></div><button class="btn btn-primary" style="width:100%" onclick="document.getElementById('validationModal').style.display='none'">Rozumiem</button></div></div>

    <script>
        // CONFIG
        const Config = {
            countries: ["Polska", "Niemcy", "Ukraina", "Wielka Brytania", "USA"],
            cities: { '00': 'Warszawa', '01': 'Warszawa', '30': 'Kraków', '40': 'Katowice', '50': 'Wrocław', '41': 'Bytom', '80': 'Gdańsk', '90': 'Łódź' }
        };
        
        // STATE
        const State = {
            step: 1, age: 0, group: 0, plan: null, addons: new Map(), apk: null
        };

        // APP LOGIC
        const App = {
            init: () => {
                ['obywatelstwo', 'obywatelstwo2', 'kraj', 'benKraj', 'benObywatelstwo'].forEach(id => {
                    const el = document.getElementById(id);
                    if(el) Config.countries.forEach(c => { 
                        let o = document.createElement('option'); o.text = c; 
                        if(c==='Polska' && id!=='obywatelstwo2') o.selected=true; 
                        el.add(o); 
                    });
                });
                App.updateProgress();
                App.bindZipHandlers();
            },
            
            updateProgress: () => {
                const totalSteps = 9;
                const p = ((State.step-1)/(totalSteps-1))*100; document.getElementById('progressFill').style.width = p+'%';
                for(let i=1; i<=totalSteps; i++) {
                    const el = document.getElementById('s'+i);
                    if(el) el.className = i<State.step ? 'step completed' : (i===State.step ? 'step active' : 'step');
                }
            },

            showStep: (s) => {
                document.querySelectorAll('.step-content').forEach(e=>e.classList.remove('active'));
                document.getElementById('step-'+s).classList.add('active');
                State.step = s; App.updateProgress(); window.scrollTo(0,0);
                
                document.getElementById('stickySummary').style.display = (s > 2 && s < 9) ? 'flex' : 'none';
                if(s === 7) App.renderSummary(); // step 7 is Weryfikacja
            },
            nextStep: () => App.showStep(State.step+1),
            prevStep: () => App.showStep(State.step-1),

            // STEP 1: APK
            validateAPK: () => {
                const q1 = document.querySelector('input[name="apk_q1"]:checked')?.value;
                const q2 = document.querySelector('input[name="apk_q2"]:checked')?.value;
                
                const btn = document.getElementById('btnStep1');
                const msg = document.getElementById('apkRejectMsg');

                if (!q1 || !q2) {
                    btn.disabled = true;
                    msg.classList.add('hidden');
                    return;
                }

                if (q1 === 'NO' || q2 === 'OUT') {
                    btn.disabled = true;
                    msg.classList.remove('hidden'); 
                } else {
                    btn.disabled = false; 
                    msg.classList.add('hidden'); 
                    State.apk = { zainteresowany: q1, grupa_wiekowa: q2 };
                }
            },

            // STEP 2: AGE
            calculateAgeGroup: () => {
                const val = document.getElementById('dataUrodzenia').value;
                if(!val) return;
                const dob = new Date(val); const now = new Date();
                let age = now.getFullYear() - dob.getFullYear();
                State.age = age;
                
                // NEW BRACKETS LOGIC
                if(age >= 16 && age <= 55) State.group = 1;
                else if(age >= 56 && age <= 69) State.group = 2;
                else if(age >= 70 && age <= 75) State.group = 3;
                else State.group = 0;
                
                const btn = document.getElementById('btnStep2'); const res = document.getElementById('ageResult');
                if(State.group > 0) {
                    btn.disabled = false; res.innerText = `Zakwalifikowano do: Grupa ${State.group} (${age} lat)`; 
                    App.renderPackages(State.group); App.renderBricks(State.group);
                } else { btn.disabled = true; res.innerText = `Wiek poza zakresem (16-75 lat). Obliczony wiek: ${age} lat.`; }
            },
            validateStep2: () => { if(State.group>0) { App.nextStep(); } },

            // STEP 3: PACKAGES
            renderPackages: (g) => {
                const c = document.getElementById('packagesContainer'); c.innerHTML='';
                let pkgs = [];
                if(g===1) pkgs = [{n:'Start',p:59,f:['Śmierć NW: 100 000 zł','Pobyt w szpitalu']},{n:'Standard',p:79,f:['Śmierć NW: 150 000 zł','Urodzenie dziecka']},{n:'Family',p:119,f:['Ochrona rodziny','Dziecko']},{n:'Premium',p:149,f:['Śmierć NW: 700 000 zł','Wysoka ochrona']},{n:'VIP',p:199,f:['Śmierć NW: 1 000 000 zł','Najwyższa ochrona']}];
                else if(g===2) pkgs = [{n:'Silver 55+',p:89,f:['Śmierć kom.: 100 000 zł','Pobyt w szpitalu']},{n:'Gold 55+',p:149,f:['Śmierć kom.: 250 000 zł','Średnia ochrona']},{n:'Platinum 55+',p:249,f:['Śmierć kom.: 500 000 zł','Najwyższa ochrona']}];
                else pkgs = [{n:'Senior Silver',p:69,f:['Śmierć NW: 30 000 zł','Dożywotnia ochrona']},{n:'Senior Gold',p:99,f:['Śmierć NW: 50 000 zł','Rozszerzona ochrona']}];
                
                pkgs.forEach((p, idx) => {
                    const div = document.createElement('div'); div.className = 'plan-card';
                    let isSel = (g===1&&idx===1)||(g===2&&idx===1)||(g===3&&idx===0);
                    if(isSel) { div.classList.add('selected'); State.plan = p; }
                    
                    div.innerHTML = `<div class="plan-header"><div class="plan-title">${p.n}</div><div class="plan-price">${p.p} zł</div></div><div class="plan-features"><ul>${p.f.map(x=>`<li><span class="material-icons-outlined check-icon">check</span> ${x}</li>`).join('')}</ul></div>`;
                    div.onclick = () => {
                        document.querySelectorAll('.plan-card').forEach(e=>e.classList.remove('selected'));
                        div.classList.add('selected'); State.plan = p; App.updateTotal();
                    };
                    c.appendChild(div);
                });
            },
            
            // STEP 4: BRICKS
            renderBricks: (g) => {
                const c = document.getElementById('bricksContainer'); c.innerHTML=''; State.addons.clear();
                if(g===3) { c.innerHTML='<p style="text-align:center">Brak cegiełek dla Seniorów</p>'; return; }
                
                const d1 = document.createElement('div'); d1.className='form-section';
                d1.innerHTML=`<h3>Cegiełki Podstawowe</h3><div class="options-grid">
                    <label class="option-card"><input type="checkbox" onchange="App.toggleAddon('act',29.90,'Active')"><div class="option-content"><strong>Active (+29,90 zł)</strong><small>Urazy, Sport</small></div></label>
                    <label class="option-card"><input type="checkbox" onchange="App.toggleAddon('kid',29.90,'Kids')"><div class="option-content"><strong>Kids (+29,90 zł)</strong><small>Dzieci, Szpital</small></div></label>
                </div>`;
                c.appendChild(d1);

                const sp = g===1 ? 29.90 : 49.90;
                const onkoDesc = g===1 ? 'Nowotwór: 40 000 zł' : 'Nowotwór: 20 000 zł';
                const kardioDesc = g===1 ? 'Zawał/Udar: 50 000 zł' : 'Zawał/Udar: 20 000 zł';

                const d2 = document.createElement('div'); d2.className='form-section';
                d2.innerHTML = `<h3>Pakiety Specjalistyczne</h3>
                    <div style="margin-bottom:10px; background:#f9f9f9; padding:10px; border-left:3px solid var(--ovb-blue);">Czy w ostatnich 5 latach diagnozowano/leczono u Ciebie nowotwór lub zawał/udar serca?</div>
                    <div style="margin-bottom:15px"><button class="btn btn-secondary" onclick="App.toggleMed(false,this)">TAK (Chorowałem)</button> <button class="btn btn-secondary" onclick="App.toggleMed(true,this)">NIE (Jestem zdrowy)</button></div>
                    <div id="medOptions" class="hidden options-grid">
                        <label class="option-card"><input type="checkbox" id="chk_onko" onchange="App.toggleAddon('onko',${sp},'Onko')"><div class="option-content"><strong>Onko (+${sp} zł)</strong><small>${onkoDesc}</small></div></label>
                        <label class="option-card"><input type="checkbox" id="chk_kardio" onchange="App.toggleAddon('kardio',${sp},'Kardio')"><div class="option-content"><strong>Kardio (+${sp} zł)</strong><small>${kardioDesc}</small></div></label>
                    </div>`;
                c.appendChild(d2);
                App.updateTotal();
            },
            toggleMed: (ok, btn) => {
                btn.parentElement.querySelectorAll('button').forEach(b=>{b.style.background='transparent'; b.style.color='var(--ovb-grey-text)';});
                btn.style.background=ok?'var(--ovb-teal)':'var(--ovb-hot-pink)'; btn.style.color='white';
                const d = document.getElementById('medOptions');
                if(ok) d.classList.remove('hidden'); else { d.classList.add('hidden'); ['onko','kardio'].forEach(id=>{let e=document.getElementById('chk_'+id); if(e&&e.checked){e.checked=false;App.toggleAddon(id,0,'');}});}
            },
            toggleAddon: (id, p, n) => {
                if(State.addons.has(id)) State.addons.delete(id); else State.addons.set(id, {p, n});
                App.updateTotal();
            },
            updateTotal: () => {
                let t = State.plan ? State.plan.p : 0;
                State.addons.forEach(v => t += v.p);
                const el = document.getElementById('stickyPrice');
                if(el) el.innerText = t.toFixed(2) + ' zł';
            },

            // STEP 5: DATA
            toggleBeneficiaryForm: () => {
                const t = document.querySelector('input[name="beneficiaryType"]:checked').value;
                const f = document.getElementById('beneficiaryForm');
                if(t === 'PERSON') f.classList.remove('hidden'); else f.classList.add('hidden');
            },
            copyAddressToBeneficiary: () => {
                if(document.getElementById('benSameAddress').checked) {
                    ['Ulica','NrDomu','Lokalu','KodPocztowy','Miasto'].forEach(f => {
                        let srcId = f.toLowerCase(); 
                        if(f==='KodPocztowy') srcId='kodPocztowy'; if(f==='NrDomu') srcId='nrDomu'; if(f==='NrLokalu') srcId='nrLokalu';
                        const val = document.getElementById(srcId).value;
                        document.getElementById('ben'+f).value = val;
                    });
                    const k = document.getElementById('kraj'); if(k) document.getElementById('benKraj').value = k.value;
                }
            },
            togglePartnerSection: () => document.getElementById('partnerSection').classList.toggle('hidden'),
            toggleResignSection: () => {
                const r = document.getElementById('resignSection'); r.classList.toggle('hidden');
                if(!r.classList.contains('hidden')){
                    const now = new Date(); let m = now.getMonth(); if(now.getDate()>25) m++;
                    let ld = new Date(now.getFullYear(), m+1, 0); document.getElementById('resignDate').value = ld.toLocaleDateString('pl-PL');
                }
            },
            validatePolicyNumber: (el) => { if(!el.value.includes('_')) el.classList.add('invalid'); else el.classList.remove('invalid'); },
            
            validateStep5: () => {
                const inputs = document.querySelectorAll('#step-5 input:not(.hidden input):not([type="checkbox"]):not([type="radio"]), #step-5 select:not(.hidden select)');
                let missing = [];
                inputs.forEach(i => {
                    if(i.hasAttribute('required') && !i.value) { i.classList.add('invalid'); missing.push("Pola formularza danych"); } 
                    else i.classList.remove('invalid');
                });
                if(document.querySelector('input[name="beneficiaryType"]:checked').value === 'PERSON') {
                    ['benImie','benNazwisko','benDataUrodzenia','benPokrewienstwo'].forEach(id=>{
                        if(!document.getElementById(id).value) missing.push("Dane Uposażonego");
                    });
                }
                if(missing.length > 0) { document.getElementById('modalErrorList').innerHTML = "Uzupełnij poprawnie dane osobowe i adresowe."; document.getElementById('validationModal').style.display='flex'; } 
                else App.nextStep();
            },

            // STEP 6: ZGODY
            quickFillStandard: () => {
                document.querySelectorAll('input[name="pep1"]')[1].checked=true; document.querySelectorAll('input[name="pep2"]')[1].checked=true;
                ['cons_medical','cons_share','decl_terms','decl_l4','decl_job'].forEach(id=>{let e=document.getElementById(id); if(e) e.checked=true;});
                document.querySelectorAll('input[name="healthGate"]')[0].checked=true;
            },
            clearStep6: () => { document.querySelectorAll('#step-6 input').forEach(i=>i.checked=false); },
            validateStep6: () => {
                let missing = [];
                if(!document.querySelector('input[name="pep1"]:checked')) missing.push("Oświadczenie PEP");
                ['cons_medical','cons_share','decl_terms','decl_l4','decl_job'].forEach(id=>{if(!document.getElementById(id).checked) missing.push("Wymagane zgody i oświadczenia");});
                const h=document.querySelector('input[name="healthGate"]:checked');
                if(!h) missing.push("Oświadczenie o zdrowiu"); else if(h.value==='NO') {alert("Wymagana ankieta medyczna. Dalszy proces w aplikacji zablokowany."); return;}
                if(missing.length>0) {
                     document.getElementById('modalErrorList').innerHTML = [...new Set(missing)].join('<br>');
                     document.getElementById('validationModal').style.display='flex';
                } else App.nextStep();
            },

            // STEP 7: SUMMARY
            renderSummary: () => {
                const d = (id) => document.getElementById(id) ? document.getElementById(id).value : '--';
                if(State.plan) {
                    document.getElementById('sum-plan').innerText = State.plan.n + ` (${State.plan.p} zł)`;
                    document.getElementById('sum-plan-desc').innerText = State.plan.f.join(', ');
                }
                document.getElementById('sum-name').innerText = d('imie')+' '+d('nazwisko');
                document.getElementById('sum-pesel').innerText = d('pesel');
                document.getElementById('sum-address').innerText = `${d('ulica')} ${d('nrDomu')}, ${d('miasto')}`;
                
                const ben = document.querySelector('input[name="beneficiaryType"]:checked').value;
                if(ben==='KC') document.getElementById('sum-beneficiary-data').innerText="Kodeks Cywilny";
                else document.getElementById('sum-beneficiary-data').innerText=`${d('benImie')} ${d('benNazwisko')} (${d('benDataUrodzenia')})`;
                
                document.getElementById('sum-total').innerText = document.getElementById('stickyPrice').innerText;
            },

            // STEP 8 & 9
            sendSMS: () => {
                document.getElementById('smsStep1').classList.add('hidden');
                document.getElementById('smsStep2').classList.remove('hidden');
                alert('Kod to: 123456');
            },
            verifySMS: () => { 
                setTimeout(()=>{
                    App.nextStep(); 
                    document.getElementById('stickySummary').style.display='none';
                    document.getElementById('finalAmount').innerText=document.getElementById('sum-total').innerText;
                }, 500); 
            },
            
            // ZIP HANDLER
            bindZipHandlers: () => {
                const handler = (srcId, targetId) => {
                    document.getElementById(srcId).addEventListener('input', (e) => {
                        let v = e.target.value.replace(/\D/g, '');
                        if(v.length>2) v = v.substring(0,2)+'-'+v.substring(2,5);
                        e.target.value = v;
                        if(v.length>=2 && Config.cities[v.substring(0,2)]) {
                            document.getElementById(targetId).value = Config.cities[v.substring(0,2)];
                        }
                    });
                };
                handler('kodPocztowy', 'miasto');
                handler('benKod', 'benMiasto');
            }
        };

        window.App = App;
        window.onload = App.init;
    </script>
</body>
</html>
